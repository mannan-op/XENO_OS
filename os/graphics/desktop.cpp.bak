#include "desktop.h"
#include <algorithm>


Desktop::Desktop(Memory* mem, ProcessManager* pm, int cpuCores, int storageGB) {
    // Icon layout parameters
    const int iconSize = 80;
    const int startX = 80;
    const int colGap = 140; // reduced horizontal gap between columns
    const int topY = 180; // increased gap from top
    const int rowGap = 140; // reduced vertical gap between rows

    terminalIcon = { startX, topY, iconSize, iconSize };
    loggerIcon = { startX, topY + rowGap, iconSize, iconSize };
    schedulerIcon = { startX + colGap, topY, iconSize, iconSize };
    bookingIcon = { startX + colGap, topY + rowGap, iconSize, iconSize };
    systemLogIcon = { startX + colGap*2, topY + rowGap, iconSize, iconSize };

    memory = mem;
    processManager = pm;
    cpu = cpuCores;
    storage = storageGB;
    backgroundReady = false;
}

namespace {
    process_id_t GetWindowPid(Window* win) {
        if (win == nullptr) {
            return 0;
        }
        return win->getPid();
    }
}

Desktop::~Desktop() {
    if (backgroundReady) {
        UnloadTexture(backgroundTexture);
    }

    for (auto* win : windows) {
        delete win;
    }
    windows.clear();
}

void Desktop::ensureBackground() {
    if (backgroundReady) {
        return;
    }

    const char* candidates[] = {
        "graphics/assets/background.jpg",
        "assets/lock-background.jpg",
        "assets/background.jpg",
        "background.jpg",
        "graphics/assets/background.png",
        "assets/lock-background.png",
        "assets/background.png",
        "background.png"
    };

    for (const char* path : candidates) {
        if (FileExists(path)) {
            backgroundTexture = LoadTexture(path);
            if (backgroundTexture.width > 0 && backgroundTexture.height > 0) {
                backgroundReady = true;
                return;
            }
            // Failed to load valid image data, unload any partial data and try next candidate
            UnloadTexture(backgroundTexture);
        }
    }
}

void Desktop::update() {
    Vector2 mouse = GetMousePosition();
    bool clickedWindow = false;

    if (IsMouseButtonPressed(MOUSE_LEFT_BUTTON)) {
        for (int i = (int)windows.size() - 1; i >= 0; --i) {
            if (!windows[i]->isActive()) {
                continue;
            }

            if (windows[i]->containsPoint(mouse)) {
                clickedWindow = true;

                Window* selected = windows[i];
                windows.erase(windows.begin() + i);
                windows.push_back(selected);

                for (auto* win : windows) {
                    win->setFocused(false);
                    process_id_t pid = GetWindowPid(win);
                    if (pid != 0) {
                        processManager->setProcessState(pid, READY, "Window moved to background");
                    }
                }
                selected->setFocused(true);
                process_id_t selectedPid = GetWindowPid(selected);
                if (selectedPid != 0) {
                    processManager->setProcessState(selectedPid, RUNNING, "Window moved to foreground");
                }
                break;
            }
        }

        if (!clickedWindow && CheckCollisionPointRec(mouse, terminalIcon)) {
            Process* terminalProcess = processManager->createProcess("Terminal", 1);
            process_id_t terminalPid = terminalProcess ? terminalProcess->pid : 0;
            for (auto* win : windows) {
                win->setFocused(false);
                process_id_t pid = GetWindowPid(win);
                if (pid != 0) {
                    processManager->setProcessState(pid, READY, "Window moved to background");
                }
            }

            Window* newTerminal = new TerminalWindow(memory, cpu, storage, terminalPid);
            newTerminal->setFocused(true);
            windows.push_back(newTerminal);

            if (terminalPid != 0) {
                processManager->setProcessState(terminalPid, RUNNING, "Window moved to foreground");
            }
        }

        if (!clickedWindow && CheckCollisionPointRec(mouse, loggerIcon)) {
            Process* loggerProcess = processManager->createProcess("Logger", 1);
            process_id_t loggerPid = loggerProcess ? loggerProcess->pid : 0;

            for (auto* win : windows) {
                win->setFocused(false);
                process_id_t pid = GetWindowPid(win);
                if (pid != 0) {
                    processManager->setProcessState(pid, READY, "Window moved to background");
                }
            }

            Window* logger = new LoggerWindow(processManager, loggerPid);
            logger->setFocused(true);
            windows.push_back(logger);

            if (loggerPid != 0) {
                processManager->setProcessState(loggerPid, RUNNING, "Window moved to foreground");
            }
        }

        if (!clickedWindow && CheckCollisionPointRec(mouse, schedulerIcon)) {
            Process* schedulerProcess = processManager->createProcess("Scheduler", 1);
            process_id_t schedulerPid = schedulerProcess ? schedulerProcess->pid : 0;

            for (auto* win : windows) {
                win->setFocused(false);
                process_id_t pid = GetWindowPid(win);
                if (pid != 0) {
                    processManager->setProcessState(pid, READY, "Window moved to background");
                }
            }

            Window* scheduler = new SchedulerWindow(processManager, schedulerPid);
            scheduler->setFocused(true);
            windows.push_back(scheduler);

            if (schedulerPid != 0) {
                processManager->setProcessState(schedulerPid, RUNNING, "Window moved to foreground");
            }
        }

        if (!clickedWindow && CheckCollisionPointRec(mouse, bookingIcon)) {
            Process* bookingProcess = processManager->createProcess("Railway Reservation", 1);
            process_id_t bookingPid = bookingProcess ? bookingProcess->pid : 0;

            for (auto* win : windows) {
                win->setFocused(false);
                process_id_t pid = GetWindowPid(win);
                if (pid != 0) {
                    processManager->setProcessState(pid, READY, "Window moved to background");
                }
            }

            Window* bookingApp = new RailwayReservationWindow(processManager, bookingPid);
            bookingApp->setFocused(true);
            windows.push_back(bookingApp);

            if (bookingPid != 0) {
                processManager->setProcessState(bookingPid, RUNNING, "Window moved to foreground");
            }
        }

        if (!clickedWindow && CheckCollisionPointRec(mouse, systemLogIcon)) {
            Process* logProcess = processManager->createProcess("System Log", 1);
            process_id_t logPid = logProcess ? logProcess->pid : 0;

            for (auto* win : windows) {
                win->setFocused(false);
                process_id_t pid = GetWindowPid(win);
                if (pid != 0) {
                    processManager->setProcessState(pid, READY, "Window moved to background");
                }
            }

            Window* logViewer = new FileViewerWindow("System Log", processManager->getSystemLogFilePath(), "system_log.txt is empty.", logPid);
            logViewer->setFocused(true);
            windows.push_back(logViewer);

            if (logPid != 0) {
                processManager->setProcessState(logPid, RUNNING, "Window moved to foreground");
            }
        }

    }

    // Update all windows
    for (auto* win : windows) {
        win->update();
    }

    windows.erase(std::remove_if(windows.begin(), windows.end(), [this](Window* win) {
        if (win->isActive()) {
            return false;
        }

        TerminalWindow* terminal = dynamic_cast<TerminalWindow*>(win);
        if (terminal != nullptr) {
            processManager->terminateProcess(terminal->getPid());
        }

        LoggerWindow* logger = dynamic_cast<LoggerWindow*>(win);
        if (logger != nullptr) {
            processManager->terminateProcess(logger->getPid());
        }

        SchedulerWindow* scheduler = dynamic_cast<SchedulerWindow*>(win);
        if (scheduler != nullptr) {
            processManager->terminateProcess(scheduler->getPid());
        }

        FileViewerWindow* fileViewer = dynamic_cast<FileViewerWindow*>(win);
        if (fileViewer != nullptr) {
            processManager->terminateProcess(fileViewer->getPid());
        }

        RailwayReservationWindow* railway = dynamic_cast<RailwayReservationWindow*>(win);
        if (railway != nullptr) {
            processManager->terminateProcess(railway->getPid());
        }

        delete win;
        return true;
    }), windows.end());
}

void Desktop::draw() {
    ensureBackground();

    int screenW = GetScreenWidth();
    int screenH = GetScreenHeight();

    if (backgroundReady) {
        Rectangle src = { 0, 0, (float)backgroundTexture.width, (float)backgroundTexture.height };
        Rectangle dst = { 0, 0, (float)screenW, (float)screenH };
        DrawTexturePro(backgroundTexture, src, dst, { 0, 0 }, 0.0f, WHITE);
        DrawRectangle(0, 0, screenW, screenH, Fade(BLACK, 0.35f));
    }
    else {
        DrawRectangleGradientV(0, 0, screenW, screenH, Color{ 23, 43, 72, 255 }, Color{ 9, 19, 35, 255 });
    }

    DrawCircle(screenW - 180, 120, 200, Fade(SKYBLUE, 0.10f));
    DrawCircle(120, screenH - 110, 230, Fade(BLUE, 0.12f));

    Rectangle statusCard = { 24, 18, 330, 86 };
    DrawRectangleRounded(statusCard, 0.14f, 16, Fade(BLACK, 0.34f));
    DrawRectangleLinesEx(statusCard, 1.4f, Fade(RAYWHITE, 0.20f));
    DrawText("Mini OS Desktop", 38, 34, 26, RAYWHITE);
    DrawText(TextFormat("CPU: %d cores | RAM: %dGB | Disk: %dGB", cpu, memory->getTotal(), storage), 38, 68, 17, Fade(RAYWHITE, 0.70f));

    Rectangle iconCard = { terminalIcon.x - 14, terminalIcon.y - 14, terminalIcon.width + 28, terminalIcon.height + 52 };
    DrawRectangleRounded(iconCard, 0.22f, 14, Fade(BLACK, 0.30f));
    DrawRectangleLinesEx(iconCard, 1.2f, Fade(RAYWHITE, 0.20f));

    DrawRectangleRounded(terminalIcon, 0.20f, 14, Color{ 31, 46, 80, 255 });
    DrawRectangle(terminalIcon.x + 11, terminalIcon.y + 12, terminalIcon.width - 22, terminalIcon.height - 26, Color{ 15, 18, 29, 255 });
    DrawRectangle(terminalIcon.x + 14, terminalIcon.y + 16, terminalIcon.width - 28, 4, Color{ 58, 88, 140, 255 });
    DrawText("_", terminalIcon.x + 20, terminalIcon.y + 28, 16, Color{ 113, 237, 182, 255 });
    { const char* lbl = "Terminal"; int tw = MeasureText(lbl, 18); DrawText(lbl, (int)(terminalIcon.x + terminalIcon.width/2) - tw/2, terminalIcon.y + terminalIcon.height + 10, 18, RAYWHITE); }

    Rectangle loggerCard = { loggerIcon.x - 14, loggerIcon.y - 14, loggerIcon.width + 28, loggerIcon.height + 52 };
    DrawRectangleRounded(loggerCard, 0.22f, 14, Fade(BLACK, 0.30f));
    DrawRectangleLinesEx(loggerCard, 1.2f, Fade(RAYWHITE, 0.20f));

    DrawRectangleRounded(loggerIcon, 0.20f, 14, Color{ 35, 59, 75, 255 });
    DrawRectangle(loggerIcon.x + 11, loggerIcon.y + 12, loggerIcon.width - 22, loggerIcon.height - 26, Color{ 16, 24, 33, 255 });
    for (int i = 0; i < 4; ++i) {
        DrawRectangle(loggerIcon.x + 16, loggerIcon.y + 19 + i * 9, loggerIcon.width - 32, 4, Color{ 88, 180, 220, 255 });
    }
    { const char* lbl = "Logger"; int tw = MeasureText(lbl, 18); DrawText(lbl, (int)(loggerIcon.x + loggerIcon.width/2) - tw/2, loggerIcon.y + loggerIcon.height + 10, 18, RAYWHITE); }

    Rectangle schedulerCard = { schedulerIcon.x - 14, schedulerIcon.y - 14, schedulerIcon.width + 28, schedulerIcon.height + 52 };
    DrawRectangleRounded(schedulerCard, 0.22f, 14, Fade(BLACK, 0.30f));
    DrawRectangleLinesEx(schedulerCard, 1.2f, Fade(RAYWHITE, 0.20f));

    DrawRectangleRounded(schedulerIcon, 0.20f, 14, Color{ 55, 44, 82, 255 });
    DrawRectangle(schedulerIcon.x + 11, schedulerIcon.y + 12, schedulerIcon.width - 22, schedulerIcon.height - 26, Color{ 26, 20, 40, 255 });
    DrawRectangle(schedulerIcon.x + 18, schedulerIcon.y + 20, 12, 24, Color{ 110, 169, 255, 255 });
    DrawRectangle(schedulerIcon.x + 33, schedulerIcon.y + 28, 12, 16, Color{ 143, 237, 182, 255 });
    DrawRectangle(schedulerIcon.x + 48, schedulerIcon.y + 16, 12, 28, Color{ 255, 218, 142, 255 });
    { const char* lbl = "Scheduler"; int tw = MeasureText(lbl, 18); DrawText(lbl, (int)(schedulerIcon.x + schedulerIcon.width/2) - tw/2, schedulerIcon.y + schedulerIcon.height + 10, 18, RAYWHITE); }

    Rectangle bookingCard = { bookingIcon.x - 14, bookingIcon.y - 14, bookingIcon.width + 28, bookingIcon.height + 52 };
    DrawRectangleRounded(bookingCard, 0.22f, 14, Fade(BLACK, 0.30f));
    DrawRectangleLinesEx(bookingCard, 1.2f, Fade(RAYWHITE, 0.20f));

    DrawRectangleRounded(bookingIcon, 0.20f, 14, Color{ 42, 72, 52, 255 });
    DrawRectangle(bookingIcon.x + 14, bookingIcon.y + 12, bookingIcon.width - 28, bookingIcon.height - 27, Color{ 18, 28, 23, 255 });
    DrawText("B", bookingIcon.x + 30, bookingIcon.y + 23, 24, Color{ 159, 229, 178, 255 });
    { const char* lbl = "Railway"; int tw = MeasureText(lbl, 18); DrawText(lbl, (int)(bookingIcon.x + bookingIcon.width/2) - tw/2, bookingIcon.y + bookingIcon.height + 10, 18, RAYWHITE); }

    Rectangle systemLogCard = { systemLogIcon.x - 14, systemLogIcon.y - 14, systemLogIcon.width + 28, systemLogIcon.height + 52 };
    DrawRectangleRounded(systemLogCard, 0.22f, 14, Fade(BLACK, 0.30f));
    DrawRectangleLinesEx(systemLogCard, 1.2f, Fade(RAYWHITE, 0.20f));

    DrawRectangleRounded(systemLogIcon, 0.20f, 14, Color{ 70, 52, 52, 255 });
    DrawRectangle(systemLogIcon.x + 14, systemLogIcon.y + 12, systemLogIcon.width - 28, systemLogIcon.height - 27, Color{ 28, 18, 18, 255 });
    DrawText("L", systemLogIcon.x + 32, systemLogIcon.y + 23, 24, Color{ 255, 210, 160, 255 });
    { const char* lbl = "System Log"; int tw = MeasureText(lbl, 18); DrawText(lbl, (int)(systemLogIcon.x + systemLogIcon.width/2) - tw/2, systemLogIcon.y + systemLogIcon.height + 10, 18, RAYWHITE); }


    Rectangle dock = { (float)screenW / 2.0f - 230, (float)screenH - 72, 460, 48 };
    DrawRectangleRounded(dock, 0.5f, 20, Fade(BLACK, 0.33f));
    DrawRectangleLinesEx(dock, 1.0f, Fade(RAYWHITE, 0.18f));
    DrawText("Applications", (int)dock.x + 162, (int)dock.y + 14, 18, Fade(RAYWHITE, 0.78f));

    for (auto* win : windows) {
        if (win->isActive())
            win->draw();
    }
}

