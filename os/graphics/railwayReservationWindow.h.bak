#pragma once

#include "windows.h"
#include "../system/process.h"
#include "../system/processManager.h"
#include <string>
#include <vector>

class RailwayReservationWindow : public Window {
private:
    struct TicketRecord {
        int id;
        std::string passenger;
        std::string train;
        std::string source;
        std::string destination;
        std::string travelDate;
        std::string status;
    };

    enum class Field {
        Passenger,
        Train,
        Source,
        Destination,
        TravelDate,
        CancelId,
        None
    };

    ProcessManager* processManager;
    process_id_t pid;
    std::vector<TicketRecord> tickets;
    std::string bookingFilePath;
    std::string passengerInput;
    std::string trainInput;
    std::string sourceInput;
    std::string destinationInput;
    std::string dateInput;
    std::string cancelInput;
    std::string statusMessage;
    Field activeField;
    int listScroll;
    int nextTicketId;

    void loadTickets();
    void saveTickets() const;
    void appendStatus(const std::string& message);
    process_id_t startRequestProcess(const std::string& requestName, int memoryUsage);
    void finishRequestProcess(process_id_t requestPid);
    void handleTextInput(std::string& value, int maxLength);
    void bookTicket();
    void cancelTicket();
    TicketRecord* findTicketById(int ticketId);
    const TicketRecord* findTicketById(int ticketId) const;
    static std::vector<std::string> split(const std::string& text, char delimiter);
    static std::string trim(const std::string& text);
    static bool isDigits(const std::string& text);

public:
    RailwayReservationWindow(ProcessManager* pm, process_id_t processId);

    void update() override;
    void drawContent() override;

    process_id_t getPid() const;
};
