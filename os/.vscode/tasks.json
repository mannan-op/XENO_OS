{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Raylib Project",
      "type": "shell",
      "command": "g++",
      "args": [
        "main.cpp",
        "graphics/*.cpp",
        "system/*.cpp",
        "boot/*.cpp",
        "-o",
        "main",
        "-lraylib",
        "-lGL",
        "-lm",
        "-lpthread",
        "-ldl",
        "-lrt",
        "-lX11"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
